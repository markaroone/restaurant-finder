{
  "name": "restaurant-finder-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "check": "bun scripts/run-checks.js",
    "fix": "bun scripts/run-checks.js --fix",
    "ready": "bun run fix && bun run typecheck",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "geoip-lite": "^2.0.0",
    "helmet": "^8.1.0",
    "ky": "^1.14.3",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/geoip-lite": "^1.4.4",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "bun-types": "latest",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "ora": "^8.2.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
